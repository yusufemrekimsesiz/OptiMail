<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OptiMail.ViewModels"
             xmlns:models="clr-namespace:OptiMail.Models"
             xmlns:conv="clr-namespace:OptiMail.Converters"
             x:Class="OptiMail.MainPage"
             x:DataType="vm:MainViewModel"
             Title="OptiMail"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F7F7FA, Dark=#151517}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:AciliyetToColorConverter x:Key="AciliyetRenkConverter" />
            <conv:InvertedBoolConverter x:Key="InvertedBool" />
            <conv:CountToBoolConverter x:Key="HasItems" />
            <conv:CountToInverseBoolConverter x:Key="NoItems" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20,16,20,16" RowSpacing="0">

        
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <Label Grid.Column="0"
                   Text="OptiMail"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />

            <Button Grid.Column="1"
                    Text="⚙️ Ayarlar"
                    Clicked="OnSettingsClicked"
                    BackgroundColor="Transparent"
                    TextColor="#4A6FE3"
                    FontSize="14"
                    Padding="0"
                    VerticalOptions="Center" />
        </Grid>

        
        <Label Grid.Row="1"
               Text="{Binding StatusMessage}"
               FontSize="13"
               TextColor="{AppThemeBinding Light=#8A8A8E, Dark=#9A9A9E}"
               Margin="0,0,0,16" />

       
        <Grid Grid.Row="2">

            <CollectionView ItemsSource="{Binding GroupedEmails}"
                             IsGrouped="True"
                             IsVisible="{Binding GroupedEmails.Count, Converter={StaticResource HasItems}}">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:EmailGroup">
                        <Border StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#EDEBFB, Dark=#2A2740}"
                                Padding="12,6"
                                Margin="0,18,0,8"
                                HorizontalOptions="Start">
                            <Label Text="{Binding KategoriAdi}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#5B4FE0, Dark=#B7ADFF}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:EmailMessage">
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="{AppThemeBinding Light=#ECECEF, Dark=#2E2E32}"
                                StrokeThickness="1"
                                Padding="16"
                                Margin="0,0,0,10"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1F1F22}">

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">

                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Subject}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}"
                                           LineBreakMode="TailTruncation" />

                                    <Border Grid.Column="1"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            Padding="8,3"
                                            VerticalOptions="Start"
                                            BackgroundColor="{Binding Analysis.Aciliyet, Converter={StaticResource AciliyetRenkConverter}}">
                                        <Label Text="{Binding Analysis.Aciliyet}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1"
                                       Text="{Binding Analysis.Ozet}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#5B5B60, Dark=#B0B0B5}"
                                       LineBreakMode="WordWrap" />

                                <Label Grid.Row="2"
                                       Text="{Binding From}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#B0B0B5, Dark=#6E6E72}" />

                                <VerticalStackLayout Grid.Row="3"
                                                     Spacing="3"
                                                     Margin="0,6,0,0"
                                                     IsVisible="{Binding Analysis.AksiyonMaddeleri, Converter={StaticResource HasItems}}">

                                    <BoxView HeightRequest="1"
                                             Color="{AppThemeBinding Light=#F0F0F2, Dark=#2E2E32}"
                                             Margin="0,0,0,4" />

                                    <Label Text="YAPILACAKLAR"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           CharacterSpacing="0.5"
                                           TextColor="{AppThemeBinding Light=#B0B0B5, Dark=#6E6E72}" />

                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Analysis.AksiyonMaddeleri}"
                                                         Spacing="3">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Label Text="{Binding ., StringFormat='•  {0}'}"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#5B5B60, Dark=#B0B0B5}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

           
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 IsVisible="{Binding GroupedEmails.Count, Converter={StaticResource NoItems}}">
                <Label Text="📭"
                       FontSize="40"
                       HorizontalOptions="Center" />
                <Label Text="Henüz analiz edilmiş mail yok"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#B0B0B5, Dark=#6E6E72}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <Button Grid.Row="3"
                Text="E-postaları Getir ve Analiz Et"
                Command="{Binding LoadEmailsCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}"
                CornerRadius="26"
                HeightRequest="52"
                FontAttributes="Bold"
                TextColor="White"
                Margin="0,12,0,0">
            <Button.Triggers>
                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="BackgroundColor" Value="#C4C4C8" />
                </DataTrigger>
                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                    <Setter Property="BackgroundColor" Value="#4A6FE3" />
                </DataTrigger>
            </Button.Triggers>
        </Button>
    </Grid>
</ContentPage>

